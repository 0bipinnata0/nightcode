    "react": ">=19.0.0",
    "react-router": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nightcode/server": "workspace:*",
    "@types/bun": "latest",
    "@types/react": ">=19.0.0",
    "typescript": "latest"
  }
}
